 package.json                               |   6 +-
 prisma/schema.prisma                       |  11 +-
 src/app/(app)/dashboard/diagnostic-tab.tsx |  21 +--
 src/app/api/dashboard/heatmap/route.ts     |  52 ++++++
 src/auth.config.ts                         |  41 +++++
 src/auth.ts                                |  43 ++---
 src/lib/rate-limit.ts                      |  37 +++++
 src/middleware.ts                          |   7 +-
 src/types/api.ts                           |   6 +
 12 files changed, 279 insertions(+), 155 deletions(-)
 create mode 100644 src/app/api/dashboard/heatmap/route.ts
 create mode 100644 src/auth.config.ts
 create mode 100644 src/lib/rate-limit.ts

diff --git a/.env.example b/.env.example
index 99cf255..a0738a0 100644
--- a/.env.example
+++ b/.env.example
@@ -1,9 +1,17 @@
-# Postgres connection string.
+# Postgres connection string used at runtime (queries).
 # Local dev (this repo's dev container): postgresql://postgres:postgres@localhost:5432/ndi_dev
-# Production (Supabase): copy the "Connection string" (URI, "Transaction" pooler) from
-#   Supabase Dashboard -> Project Settings -> Database
+# Production (Supabase): copy the "Connection string" (URI, "Transaction" pooler,
+#   usually port 6543) from Supabase Dashboard -> Project Settings -> Database
 DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ndi_dev"
 
+# Postgres connection string used only for migrations (`prisma migrate`).
+# Connection poolers (Supabase's pooler, PgBouncer in transaction mode) don't
+# support the prepared statements migrations need, so this must be the
+# *unpooled* connection (Supabase: "Connection string" -> "Session" mode,
+# usually port 5432). For local dev, or any database you connect to directly
+# without a pooler, this is identical to DATABASE_URL.
+DIRECT_URL="postgresql://postgres:postgres@localhost:5432/ndi_dev"
+
 # Auth.js — generate with: npx auth secret  (or: openssl rand -base64 32)
 AUTH_SECRET="replace-with-a-random-32-byte-secret"
 
diff --git a/next.config.mjs b/next.config.mjs
index ba95838..2bda21d 100644
--- a/next.config.mjs
+++ b/next.config.mjs
@@ -3,6 +3,21 @@ const nextConfig = {
   eslint: {
     ignoreDuringBuilds: false,
   },
+  async headers() {
+    return [
+      {
+        source: "/(.*)",
+        headers: [
+          { key: "X-Frame-Options", value: "DENY" },
+          { key: "X-Content-Type-Options", value: "nosniff" },
+          { key: "Referrer-Policy", value: "strict-origin-when-cross-origin" },
+          { key: "Permissions-Policy", value: "camera=(), microphone=(), geolocation=()" },
+          // HSTS only matters over HTTPS (Vercel/production); harmless over local HTTP.
+          { key: "Strict-Transport-Security", value: "max-age=63072000; includeSubDomains" },
+        ],
+      },
+    ];
+  },
 };
 
 export default nextConfig;
